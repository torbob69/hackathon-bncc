# ── MELATI JAYA — environment template ──────────────────────────────
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit secrets.

# Runtime mode: "dev" mocks the entire payment gateway (MockXenditProvider);
# "prod" uses the real Xendit integration.
MODE=dev

# ── Database (Supabase PostgreSQL) ───────────────────────────────────
# Direct connection (port 5432) for Railway-hosted backend.
# If switching to Supabase PgBouncer (port 6543), uncomment connect_args in engine.py.
# Get URI from: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql+asyncpg://postgres:password@db.PROJECTREF.supabase.co:5432/postgres

# ── Auth ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 characters; placeholder values are rejected at startup.
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS / frontend ──────────────────────────────────────────────────
# JSON array of allowed origins, e.g. ["http://localhost:5173","https://yourdomain.com"]
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=["http://localhost:5173"]

# ── Xendit (required only when MODE=prod; ignored by the mock in dev) ─
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=

# ── Cloudinary (KTP/SIM photo uploads) ───────────────────────────────
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# ── Debugging (never enable in deployed environments) ────────────────
LOG_SQL=false
