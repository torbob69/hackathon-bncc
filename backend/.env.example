# ── MELATI JAYA — environment template ──────────────────────────────
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit secrets.

# Runtime mode: "dev" mocks the entire payment gateway (MockXenditProvider);
# "prod" uses the real Xendit integration.
MODE=dev

# ── Database (Railway MySQL) ─────────────────────────────────────────
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/melati_jaya

# ── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Xendit (required only when MODE=prod; ignored by the mock in dev) ─
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=

# ── Cloudinary (KTP/SIM photo uploads) ───────────────────────────────
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# ── CORS / frontend ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
