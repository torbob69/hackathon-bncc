      "boundElements": null,
      "updated": 1781253348287,
      "link": null,
      "locked": false,
      "text": "There will be several entities : \n1. Koperasi\n2. Buyer/distributor\n3. Farmer\n4. Manajer\n5. Admin\n6. (possibly more)...",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "There will be several entities : \n1. Koperasi\n2. Buyer/distributor\n3. Farmer\n4. Manajer\n5. Admin\n6. (possibly more)...",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "bQ7SpOC0bZecKhrO17Ksd",
      "type": "text",
      "x": 2011.5274855229054,
      "y": 468.22222447683384,
      "width": 505.599609375,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5W",
      "roundness": null,
      "seed": 1650298317,
      "version": 354,
      "versionNonce": 377817731,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781253469935,
      "link": null,
      "locked": false,
      "text": "Each koperasi would have several members (farmers)\n\nThe marketplace app would display all koperasis\n\nEach koperasi has product catalogs",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Each koperasi would have several members (farmers)\n\nThe marketplace app would display all koperasis\n\nEach koperasi has product catalogs",
      "autoResize": true,
      "lineHeight": 1.25
    }
